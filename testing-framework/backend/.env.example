# ========== 大模型三选一（按优先级：Dify > 公司大模型 > Claude） ==========

# ---------- 方式一：Dify 平台（推荐，用公司 Dify） ----------
# Dify 应用 API 地址（在 Dify 应用「API 访问」里复制）；也可用 DIFY_BASE_URL 或 DIFY_BASE
# DIFY_API_BASE=https://your-dify.company.com/v1
# Dify 应用 API Key（在 Dify 应用「API 访问」里复制）；也可用 DIFY_KEY
# DIFY_API_KEY=app-xxxx

# ---------- 方式二：公司大模型（OpenAI 兼容接口） ----------
# 公司大模型 API 基础地址，需兼容 OpenAI /chat/completions
# LLM_BASE_URL=https://your-llm.company.com/v1
# LLM_API_KEY=your-company-llm-key
# 可选：模型名
# LLM_MODEL=gpt-3.5-turbo

# ---------- 方式三：Claude（需自行充值） ----------
# ANTHROPIC_API_KEY=sk-ant-xxx
# LLM_MODEL=claude-opus-4-6
